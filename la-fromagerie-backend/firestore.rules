// LIVE RULES — exported verbatim from the Firebase console (project
// la-fromagerie-25560) on 2026-07-08 via `firebase init firestore`.
// Keep this file identical to what is deployed: it exists so the repo reflects
// production. A hardened replacement is drafted in firestore.rules.hardened-proposal
// (NOT deployed — needs Tommy's sign-off, see FIRESTORE_RULES_AUDIT.md).
//
// ⚠️ AUDIT FINDING 2026-07-08: despite the comment below claiming admin-only
// writes, `allow write: if true` makes EVERY collection world-writable with
// nothing but the API key embedded in any APK.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
		match /{document=**} {
      // Autoriser la lecture à tous les utilisateurs
   	 	allow read: if true;

    	// Autoriser l'écriture uniquement à l'utilisateur "admin"
    	allow write: if true;
  	}
  }
}
